# EV Dashboard - Backend Environment Variables
# Copy this to .env and update the values

# =============================================================================
# DISCORD BOT
# =============================================================================

# Discord Bot Token (required for bot commands)
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token

# Discord Webhooks (for posting +EV alerts to channels)
DISCORD_WEBHOOK_PRIZEPICKS=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_UNDERDOG=https://discord.com/api/webhooks/...

# =============================================================================
# ODDS API (with automatic key rotation)
# =============================================================================

# Primary Odds API Key (required for sharp odds)
# Get free key (500 req/month): https://the-odds-api.com
ODDS_API_KEY=your_primary_odds_api_key

# Backup API Keys (optional - only use keys legitimately issued to you)
# The system automatically switches to the next key when one runs low
# ODDS_API_KEY_1=your_backup_key_1
# ODDS_API_KEY_2=your_backup_key_2
# ODDS_API_KEY_3=your_backup_key_3

# Protects cache/key/debug administration routes
ADMIN_API_KEY=generate_a_long_random_secret

# Separate least-privilege key for Hermes candidate/history endpoints
HERMES_API_KEY=generate_a_different_long_random_secret

# Durable snapshot database. Mount /data as a Railway volume in production.
DATABASE_PATH=.data/ev_bot.db

# Odds API quota controls
DFS_EVENT_LIMIT=8
DFS_MARKET_LIMIT=4
DFS_LOOKAHEAD_HOURS=36
SHARP_EVENT_LIMIT=8
SHARP_MARKET_LIMIT=4
PUBLIC_PROP_MAX_AGE_MINUTES=60
PUBLIC_EV_MAX_AGE_MINUTES=15

# Paper trading guardrails (simulation only)
PAPER_STARTING_BANKROLL=200
PAPER_STAKE=10
PAPER_DAILY_STAKE_CAP=30
PAPER_DAILY_LOSS_STOP=30
PAPER_MAX_OPEN_ENTRIES=4
PAPER_DAILY_SCAN_CAP=24
PAPER_SPORTS=mlb,nba,nfl,nhl,wnba,ncaab,ncaaf,cfl,mls,epl,summer
PAPER_HEARTBEAT_SECONDS=300
# Keep false until Railway volume + Discord webhooks are verified
PAPER_SCHEDULER_ENABLED=false

# Durable snapshot database. Mount /data as a Railway volume in production.
# DATABASE_PATH=/data/ev_bot.db

# =============================================================================
# DEPLOYMENT
# =============================================================================

# Frontend URL(s) for CORS - your Vercel deployment URL
# Local: http://localhost:3000
# Production example: https://ev-prop-bot.vercel.app
# Comma-separated list is supported.
FRONTEND_URL=https://ev-prop-bot.vercel.app

# Used by the Discord bot to read the canonical FastAPI pipeline
BACKEND_URL=http://127.0.0.1:8000

# Port for API server (Railway sets this automatically)
PORT=8000

# Run mode: "both" (default), "api", or "bot"
RUN_MODE=both
